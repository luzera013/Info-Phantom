# OMNISCIENT ULTIMATE SYSTEM FINAL - Environment Configuration
# Copy this file to .env and configure your settings

# Application Settings
OMNISCIENT_ENV=development
OMNISCIENT_LOG_LEVEL=DEBUG
OMNISCIENT_HOST=0.0.0.0
OMNISCIENT_PORT=8000
OMNISCIENT_SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
OMNISCIENT_DB_URL=sqlite:///data/omniscient.db
# PostgreSQL (alternative to SQLite)
# OMNISCIENT_DB_URL=postgresql://username:password@localhost:5432/omniscient
POSTGRES_DB=omniscient
POSTGRES_USER=omniscient
POSTGRES_PASSWORD=omniscient123

# Redis Configuration (for caching and sessions)
OMNISCIENT_REDIS_URL=redis://localhost:6379/0
OMNISCIENT_REDIS_PASSWORD=
OMNISCIENT_REDIS_DB=0

# AI Service Configuration
OMNISCIENT_OPENAI_API_KEY=your-openai-api-key
OMNISCIENT_ANTHROPIC_API_KEY=your-anthropic-api-key
OMNISCIENT_HUGGINGFACE_API_KEY=your-huggingface-api-key

# Search Engine APIs
OMNISCIENT_GOOGLE_API_KEY=your-google-api-key
OMNISCIENT_BING_API_KEY=your-bing-api-key
OMNISCIENT_BRAVE_API_KEY=your-brave-api-key

# Social Media APIs
OMNISCIENT_REDDIT_CLIENT_ID=your-reddit-client-id
OMNISCIENT_REDDIT_CLIENT_SECRET=your-reddit-client-secret
OMNISCIENT_REDDIT_USER_AGENT=omniscient/1.0
OMNISCIENT_GITHUB_TOKEN=your-github-token

# News APIs
OMNISCIENT_NEWSAPI_KEY=your-newsapi-key
OMNISCIENT_CURRENTSAPI_KEY=your-currentsapi-key
OMNISCIENT_GNEWS_API_KEY=your-gnews-api-key

# Tor Configuration
OMNISCIENT_TOR_CONTROL_PORT=9051
OMNISCIENT_TOR_SOCKS_PORT=9050
OMNISCIENT_TOR_DATA_DIR=./data/tor
OMNISCIENT_TOR_PASSWORD=your-tor-password

# Rate Limiting
OMNISCIENT_RATE_LIMIT_REQUESTS=100
OMNISCIENT_RATE_LIMIT_WINDOW=60
OMNISCIENT_RATE_LIMIT_ENABLED=true

# Cache Configuration
OMNISCIENT_CACHE_TTL=300
OMNISCIENT_CACHE_MAX_SIZE=1000
OMNISCIENT_CACHE_ENABLED=true

# File Upload Configuration
OMNISCIENT_UPLOAD_DIR=./uploads
OMNISCIENT_MAX_FILE_SIZE=50MB
OMNISCIENT_ALLOWED_EXTENSIONS=.txt,.pdf,.doc,.docx,.jpg,.jpeg,.png,.gif,.zip,.tar,.gz

# Email Configuration (for notifications)
OMNISCIENT_EMAIL_HOST=smtp.gmail.com
OMNISCIENT_EMAIL_PORT=587
OMNISCIENT_EMAIL_USERNAME=your-email@gmail.com
OMNISCIENT_EMAIL_PASSWORD=your-email-password
OMNISCIENT_EMAIL_FROM=noreply@omniscient.com
OMNISCIENT_EMAIL_USE_TLS=true

# Security Settings
OMNISCIENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
OMNISCIENT_CORS_ALLOW_CREDENTIALS=true
OMNISCIENT_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
OMNISCIENT_CORS_ALLOW_HEADERS=*

# Session Configuration
OMNISCIENT_SESSION_TIMEOUT=3600
OMNISCIENT_SESSION_COOKIE_SECURE=false
OMNISCIENT_SESSION_COOKIE_HTTPONLY=true

# Worker Configuration
OMNISCIENT_WORKER_CONCURRENCY=4
OMNISCIENT_WORKER_TIMEOUT=300
OMNISCIENT_WORKER_MAX_RETRIES=3

# Monitoring Configuration
OMNISCIENT_METRICS_ENABLED=true
OMNISCIENT_METRICS_PORT=9090
OMNISCIENT_HEALTH_CHECK_INTERVAL=30

# Logging Configuration
OMNISCIENT_LOG_FORMAT=json
OMNISCIENT_LOG_FILE=./logs/omniscient.log
OMNISCIENT_LOG_MAX_SIZE=10MB
OMNISCIENT_LOG_BACKUP_COUNT=5

# Development Settings
OMNISCIENT_DEBUG=true
OMNISCIENT_RELOAD=true
OMNISCIENT_AUTO_RELOAD=true

# Production Settings
OMNISCIENT_PRODUCTION=false
OMNISCIENT_SSL_ENABLED=false
OMNISCIENT_SSL_CERT_PATH=./ssl/cert.pem
OMNISCIENT_SSL_KEY_PATH=./ssl/key.pem

# External Service URLs
OMNISCIENT_EXTERNAL_API_TIMEOUT=30
OMNISCIENT_EXTERNAL_API_RETRIES=3

# Feature Flags
OMNISCIENT_ENABLE_TOR=true
OMNISCIENT_ENABLE_AI=true
OMNISCIENT_ENABLE_CRAWLING=true
OMNISCIENT_ENABLE_IMAGE_SEARCH=true
OMNISCIENT_ENABLE_SOCIAL_SEARCH=true
OMNISCIENT_ENABLE_NEWS_SEARCH=true
OMNISCIENT_ENABLE_KNOWLEDGE_SEARCH=true

# Performance Settings
OMNISCIENT_MAX_CONCURRENT_REQUESTS=100
OMNISCIENT_REQUEST_TIMEOUT=60
OMNISCIENT_CONNECTION_POOL_SIZE=20

# Backup Configuration
OMNISCIENT_BACKUP_ENABLED=true
OMNISCIENT_BACKUP_INTERVAL=24h
OMNISCIENT_BACKUP_DIR=./backups
OMNISCIENT_BACKUP_RETENTION_DAYS=30

# Analytics Configuration
OMNISCIENT_ANALYTICS_ENABLED=false
OMNISCIENT_ANALYTICS_PROVIDER=google
OMNISCIENT_ANALYTICS_ID=your-analytics-id

# Webhook Configuration
OMNISCIENT_WEBHOOK_URL=
OMNISCIENT_WEBHOOK_SECRET=your-webhook-secret

# Third-party Integrations
OMNISCIENT_SLACK_WEBHOOK_URL=
OMNISCIENT_DISCORD_WEBHOOK_URL=
OMNISCIENT_TELEGRAM_BOT_TOKEN=

# Proxy Configuration
OMNISCIENT_HTTP_PROXY=
OMNISCIENT_HTTPS_PROXY=
OMNISCIENT_NO_PROXY=localhost,127.0.0.1

# Selenium Configuration
OMNISCIENT_SELENIUM_DRIVER=chrome
OMNISCIENT_SELENIUM_HEADLESS=true
OMNISCIENT_SELENIUM_WINDOW_SIZE=1920,1080
OMNISCIENT_SELENIUM_TIMEOUT=30

# OCR Configuration
OMNISCIENT_TESSERACT_CMD=/usr/bin/tesseract
OMNISCIENT_TESSERACT_LANGUAGES=por,eng

# Elasticsearch Configuration (optional)
OMNISCIENT_ELASTICSEARCH_URL=http://localhost:9200
OMNISCIENT_ELASTICSEARCH_INDEX=omniscient

# Kafka Configuration (optional)
OMNISCIENT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OMNISCIENT_KAFKA_TOPIC=omniscient-events

# MinIO Configuration (optional S3-compatible storage)
OMNISCIENT_MINIO_ENDPOINT=localhost:9000
OMNISCIENT_MINIO_ACCESS_KEY=minioadmin
OMNISCIENT_MINIO_SECRET_KEY=minioadmin
OMNISCIENT_MINIO_BUCKET=omniscient

# JWT Configuration
OMNISCIENT_JWT_ALGORITHM=HS256
OMNISCIENT_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
OMNISCIENT_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Policy
OMNISCIENT_PASSWORD_MIN_LENGTH=8
OMNISCIENT_PASSWORD_REQUIRE_UPPERCASE=true
OMNISCIENT_PASSWORD_REQUIRE_LOWERCASE=true
OMNISCIENT_PASSWORD_REQUIRE_NUMBERS=true
OMNISCIENT_PASSWORD_REQUIRE_SPECIAL=true

# Rate Limiting per User
OMNISCIENT_USER_RATE_LIMIT_REQUESTS=1000
OMNISCIENT_USER_RATE_LIMIT_WINDOW=3600

# Data Retention
OMNISCIENT_DATA_RETENTION_DAYS=365
OMNISCIENT_LOG_RETENTION_DAYS=90

# API Rate Limiting
OMNISCIENT_API_RATE_LIMIT_PER_MINUTE=60
OMNISCIENT_API_RATE_LIMIT_PER_HOUR=1000
OMNISCIENT_API_RATE_LIMIT_PER_DAY=10000

# Security Headers
OMNISCIENT_SECURITY_HSTS_ENABLED=true
OMNISCIENT_SECURITY_X_FRAME_OPTIONS=DENY
OMNISCIENT_SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff

# Monitoring and Alerting
OMNISCIENT_ALERT_EMAIL_ENABLED=false
OMNISCIENT_ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
OMNISCIENT_ALERT_EMAIL_SMTP_PORT=587
OMNISCIENT_ALERT_EMAIL_USERNAME=your-alert-email@gmail.com
OMNISCIENT_ALERT_EMAIL_PASSWORD=your-alert-email-password
OMNISCIENT_ALERT_EMAIL_FROM=alerts@omniscient.com
OMNISCIENT_ALERT_EMAIL_TO=admin@omniscient.com

# Database Pool Configuration
OMNISCIENT_DB_POOL_SIZE=20
OMNISCIENT_DB_MAX_OVERFLOW=30
OMNISCIENT_DB_POOL_TIMEOUT=30

# Background Tasks
OMNISCIENT_CELERY_BROKER_URL=redis://localhost:6379/0
OMNISCIENT_CELERY_RESULT_BACKEND=redis://localhost:6379/0
OMNISCIENT_CELERY_TASK_SERIALIZER=json
OMNISCIENT_CELERY_RESULT_SERIALIZER=json

# WebSocket Configuration
OMNISCIENT_WEBSOCKET_ENABLED=true
OMNISCIENT_WEBSOCKET_PATH=/ws
OMNISCIENT_WEBSOCKET_HEARTBEAT_INTERVAL=30

# Feature-specific Settings
OMNISCIENT_MAX_SEARCH_RESULTS=1000
OMNISCIENT_DEFAULT_SEARCH_RESULTS=100
OMNISCIENT_MAX_CRAWL_DEPTH=3
OMNISCIENT_CRAWL_DELAY=1

# AI Model Configuration
OMNISCIENT_DEFAULT_AI_MODEL=gpt-4
OMNISCIENT_AI_TEMPERATURE=0.7
OMNISCIENT_AI_MAX_TOKENS=4000
OMNISCIENT_AI_TOP_P=1
OMNISCIENT_AI_FREQUENCY_PENALTY=0.0

# Image Processing
OMNISCIENT_IMAGE_MAX_SIZE=10MB
OMNISCIENT_IMAGE_QUALITY=85
OMNISCIENT_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# File Processing
OMNISCIENT_DOCUMENT_MAX_SIZE=50MB
OMNISCIENT_DOCUMENT_FORMATS=pdf,doc,docx,txt,rtf

# API Keys for External Services
# Add your API keys here for various services
# Example:
# GOOGLE_TRANSLATE_API_KEY=your-google-translate-key
# AZURE_COMPUTER_VISION_KEY=your-azure-vision-key
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Development Tools
OMNISCIENT_ENABLE_PROFILER=false
OMNISCIENT_ENABLE_DEBUG_TOOLBAR=false
OMNISCIENT_ENABLE_API_DOCS=true

# Testing Configuration
OMNISCIENT_TEST_DATABASE_URL=sqlite:///test_omniscient.db
OMNISCIENT_TEST_REDIS_URL=redis://localhost:6379/1

# Deployment Configuration
OMNISCIENT_DEPLOY_ENV=local
OMNISCIENT_CLUSTER_NAME=omniscient-cluster
OMNISCIENT_NODE_NAME=omniscient-node-1

# Backup and Recovery
OMNISCIENT_BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
OMNISCIENT_BACKUP_COMPRESSION=true
OMNISCIENT_BACKUP_ENCRYPTION_ENABLED=false

# Compliance and Privacy
OMNISCIENT_GDPR_ENABLED=true
OMNISCIENT_DATA_ANONYMIZATION=true
OMNISCIENT_CONSENT_REQUIRED=true
OMNISCIENT_PRIVACY_POLICY_URL=https://omniscient.com/privacy

# Custom Configuration
OMNISCIENT_CUSTOM_CONFIG_1=
OMNISCIENT_CUSTOM_CONFIG_2=
OMNISCIENT_CUSTOM_CONFIG_3=
